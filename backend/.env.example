PORT=4000
NODE_ENV=development

# MariaDB connection string (Prisma uses mysql provider for MariaDB)
DATABASE_URL="mysql://USER:PASSWORD@localhost:3306/smishing"

# Redis
REDIS_URL="redis://localhost:6379"

# Google Safe Browsing
GOOGLE_SAFE_BROWSING_API_KEY="change-me"

# XGBoost inference API base URL
AI_BASE_URL="http://localhost:8001"

# JWT
JWT_ACCESS_SECRET="change-me"
JWT_ACCESS_EXPIRES_IN="15m"
